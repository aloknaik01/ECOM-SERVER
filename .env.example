# Server
PORT=5000
FRONTEND_URL=http://localhost:5173
DASHBOARD_URL=http://localhost:5174

# Database (Supabase)
# IMPORTANT:
# - Use the Supabase "Connection pooler" URL when deploying on hosting providers.
# - If your DB password contains reserved characters (@ : / # ? & =), URL-encode them in DATABASE_URL.
# - Add `?sslmode=require` if not already present.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Auth
JWT_EXPIRES_IN=7d
COOKIE_EXPIRES_IN=7
JWT_SECRET_KEY=replace_me

# Email (SMTP)
SMTP_SERVICE=gmail
SMTP_MAIL=replace_me@gmail.com
SMTP_PASSWORD=replace_me
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# Gemini
GEMINI_API_KEY=replace_me

# Cloudinary
CLOUDINARY_CLIENT_NAME=replace_me
CLOUDINARY_CLIENT_API=replace_me
CLOUDINARY_CLIENT_SECRET=replace_me

# Stripe
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me
STRIPE_FRONTEND_KEY=replace_me

# Google OAuth
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
